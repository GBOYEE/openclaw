# Environment variables for outreach

# SMTP settings (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_app_password   # use app password, not main password

# From address (same as SMTP_USER)
OUTREACH_FROM=your.email@gmail.com

# Dry run (set to 0 to actually send)
OUTREACH_DRY_RUN=1